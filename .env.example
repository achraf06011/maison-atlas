# ============================================================
#  Maison Atlas Premium — Environment Variables
#  Copy this file to `.env` and fill in the values.
# ============================================================

# ----- Supabase PostgreSQL -----
# Project Settings > Database > Connection string
# Use the "Connection pooling" (Transaction) string for DATABASE_URL (port 6543)
# and the "Direct connection" string for DIRECT_URL (port 5432).
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# ----- NextAuth -----
# Generate a secret with:  openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
# Local dev: http://localhost:3000 — Production: your deployed URL
NEXTAUTH_URL="http://localhost:3000"

# ----- Seed admin account (used by prisma/seed.ts) -----
ADMIN_EMAIL="admin@maisonatlas.com"
ADMIN_PASSWORD="ChangeMe!2026"
ADMIN_NAME="Maison Atlas Admin"

# ----- Public site URL (used for SEO / sitemap) -----
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
